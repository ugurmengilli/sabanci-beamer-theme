% ==========================================================
% PART 2: BEAMER NATIVE THEME OVERRIDES
% ==========================================================
% Map the internal 'main' color engine variable expected by the Focus
% theme architecture.
\colorlet{main}{sabanciBlue}

% --> Global Presentation Canvas Base
% This ensures a high-contrast read for digital projection. The frame
% is crisp off-white, and the default text is Sabanci Blue.
\setbeamercolor{normal text}{fg=sabanciBlue, bg=sabanciWarmWhite}
\setbeamercolor{background canvas}{bg=sabanciWarmWhite}

% --> Global Structural Colors (Titles, Headers, Footers)
\setbeamercolor{structure}{fg=sabanciBlue}
\setbeamercolor{title}{fg=sabanciBlue}
\setbeamercolor{frametitle}{bg=sabanciCobaltBlue, fg=white}
\setbeamercolor{footline}{bg=sabanciCobaltBlue, fg=white}

% --> Secondary UI Artifacts
% By overriding these default palette elements, things like internal
% focus dots, progress bars, and outlines will obey the Sabanci
% hierarchy natively.
\setbeamercolor{palette primary}{bg=sabanciBlue, fg=white}
\setbeamercolor{palette secondary}{bg=sabanciWarmGray1, fg=sabanciBlue}
\setbeamercolor{palette tertiary}{bg=sabanciRed, fg=white}
\setbeamercolor{palette quaternary}{bg=sabanciOrangeBrown, fg=white}


% ==========================================================
% PART 3: BLOCK BEHAVIORS
% ==========================================================
% These overrides map the 3 variations of the "Academic Palette"
% natively into Beamer's 3 standard block definitions.

% --> Standard Block
\setbeamercolor{block title}{bg=sabanciDarkSlate, fg=white}
\setbeamercolor{block body}{bg=sabanciWarmGray1, fg=sabanciBlue}

% --> Alert Block
\setbeamercolor{block title alerted}{bg=sabanciRed, fg=white}
\setbeamercolor{block body alerted}{bg=sabanciWarmGray1, fg=sabanciBlue}

% --> Example Block
\setbeamercolor{block title example}{bg=sabanciOlive, fg=white}
\setbeamercolor{block body example}{bg=sabanciWarmGray1, fg=sabanciBlue}
