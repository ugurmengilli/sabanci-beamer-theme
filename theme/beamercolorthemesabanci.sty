% Sabanci University Beamer Color Theme
%
% Extracted from the Sabanci Corporate Identity Manual (Pages 7-11):
% Ref: https://sabanciuniv.edu/sites/default/files/2026-01/kurumsal-iletisim-kilavuzu-2025.pdf

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamercolorthemesabanci}[2026/03/21 Sabanci University Beamer Color Theme]

% The package relies on color macros like `\definecolor` and
% `\colorlet`. In Beamer `xcolor` is loaded, so this package typically
% works, but as a standalone package it's more robust to explicitly
% require `xcolor` package.
\RequirePackage{xcolor}

% ==========================================================
% PART 1: CORE IDENTITY COLORS
% ==========================================================
% These are the absolute core branding colors defined on Page 9-10 of
% the Corporate Guide. We define them using exact Pantone RGB values.
\definecolor{suBlue}{RGB}{0, 39, 118}      % Pantone 280
\definecolor{suRed}{RGB}{130, 35, 51}      % Pantone 202
\definecolor{suOrange}{RGB}{227, 114, 34}  % Pantone 158
\definecolor{suBeige}{RGB}{216, 212, 200}  % Pantone 7534
\definecolor{suLime}{RGB}{189, 206, 28}    % Pantone 382

% Secondary Tones
\definecolor{suWarmGray1}{RGB}{219, 213, 205}    % Pan. Warm Gray 1 U
\definecolor{suWarmGray4}{RGB}{155, 148, 140}
\definecolor{suLightGray}{gray}{0.70}
\definecolor{suMidGray}{gray}{0.50}
\definecolor{suPaleLime}{RGB}{205, 234, 128}     % Pantone 373
\definecolor{suOlive}{RGB}{137, 144, 35}         % Pantone 384
\definecolor{suBrightYellow}{RGB}{253, 224, 33}  % Pantone 107
\definecolor{suDarkSlate}{RGB}{51, 63, 72}       % Pantone 432
\definecolor{suPaleYellow}{RGB}{250, 210, 84}    % Pantone 121
\definecolor{suSandYellow}{RGB}{243, 192, 91}    % Pantone 142
\definecolor{suOrangeBrown}{RGB}{161, 90, 44}    % Pantone 160
\definecolor{suDarkBrown}{RGB}{99, 58, 33}       % Pantone 161
\definecolor{suBrightPink}{RGB}{218, 24, 132}    % Pantone 219
\definecolor{suPaleCyan}{RGB}{151, 212, 233}     % Pantone 324
\definecolor{suMagenta}{RGB}{166, 0, 97}         % Pantone 220
\definecolor{suMintGreen}{RGB}{127, 209, 174}    % Pantone 338
\definecolor{suCardinalRed}{RGB}{186, 12, 47}    % Pantone 200
\definecolor{suDarkGreen}{RGB}{0, 112, 74}       % Pantone 3288
\definecolor{suDarkTeal}{RGB}{0, 59, 92}         % Pantone 302
\definecolor{suDeepPurple}{RGB}{74, 30, 74}      % Pantone 5115
\definecolor{suBrightCyan}{RGB}{0, 181, 226}     % Pantone 306
\definecolor{suPlum}{RGB}{111, 66, 89}           % Pantone 5125
\definecolor{suPaleBlue}{RGB}{158, 221, 249}     % Pantone 304
\definecolor{suDustyRose}{RGB}{180, 150, 166}    % Pantone 5145
\definecolor{suMediumBlue}{RGB}{68, 105, 185}    % 79m 62c 2y 0k
\definecolor{suMediumPurple}{RGB}{156, 126, 186} % 57m 39c 4y 0k
\definecolor{suLightPurple}{RGB}{197, 175, 213}  % 35m 23c 3y 0k
\definecolor{suLavender}{RGB}{226, 216, 230}     % 16m 10c 2y 0k

% Custom Web/Digital Colors
\definecolor{suWarmWhite}{RGB}{249, 249, 249}    % mySU background
\definecolor{suCobaltBlue}{RGB}{23, 66, 137}     % from mySU

% ==========================================================
% PART 2: BEAMER NATIVE THEME OVERRIDES
% ==========================================================
% Map the internal 'main' color engine variable expected by the Focus
% theme architecture.
\colorlet{main}{suBlue}

% --> Global Presentation Canvas Base
% This ensures a high-contrast read for digital projection. The frame
% is crisp off-white, and the default text is Sabanci Blue.
\setbeamercolor{normal text}{fg=suBlue, bg=suWarmWhite}
\setbeamercolor{background canvas}{bg=suWarmWhite}

% --> Global Structural Colors (Titles, Headers, Footers)
\setbeamercolor{structure}{fg=suBlue}
\setbeamercolor{title}{fg=suBlue}
\setbeamercolor{frametitle}{bg=suCobaltBlue, fg=white}
\setbeamercolor{footline}{bg=suCobaltBlue, fg=white}

% --> Secondary UI Artifacts
% By overriding these default palette elements, things like internal
% focus dots, progress bars, and outlines will obey the Sabanci
% hierarchy natively.
\setbeamercolor{palette primary}{bg=suBlue, fg=white}
\setbeamercolor{palette secondary}{bg=suWarmGray1, fg=suBlue}
\setbeamercolor{palette tertiary}{bg=suRed, fg=white}
\setbeamercolor{palette quaternary}{bg=suOrangeBrown, fg=white}


% ==========================================================
% PART 3: BLOCK BEHAVIORS
% ==========================================================
% These overrides map the 3 variations of the "Academic Palette"
% natively into Beamer's 3 standard block definitions.

% --> Standard Block
\setbeamercolor{block title}{bg=suDarkSlate, fg=white}
\setbeamercolor{block body}{bg=suWarmGray1, fg=suBlue}

% --> Alert Block
\setbeamercolor{block title alerted}{bg=suRed, fg=white}
\setbeamercolor{block body alerted}{bg=suWarmGray1, fg=suBlue}

% --> Example Block
\setbeamercolor{block title example}{bg=suOlive, fg=white}
\setbeamercolor{block body example}{bg=suWarmGray1, fg=suBlue}
